{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tolaria",
  "version": "0.1.0",
  "identifier": "gg.modusimagery.tolaria",
  "build": {
    "frontendDist": "ui/dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tolaria",
        "width": 1380,
        "height": 880,
        "minWidth": 1040,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Locke Werks",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": {
      "../../target/release/tolaria.exe": "tolaria.exe"
    },
    "windows": {
      "signCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/sign.ps1 %1",
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
